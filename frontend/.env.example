# Copy to .env for local development only. Do not commit .env.
# Netlify: set VITE_* variables in Site settings → Environment variables.

# Backend API URL (default: http://localhost:8000)
# Local dev:
# VITE_API_BASE_URL=http://localhost:8000
# Production (your Cloud Run URL, set in Netlify before build):
# VITE_API_BASE_URL=https://your-api-xxxxx.run.app

# Enable mock API for frontend-only development (default: false)
# VITE_USE_MOCK_API=false
