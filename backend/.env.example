# Copy to .env for local development only. Do not commit .env.
# Cloud Run: set these as service environment variables instead.

# development | test | production (default: development)
# ENVIRONMENT=development

# Allowed CORS origins, comma-separated (default: http://localhost:5173)
# Local dev:
# CORS_ORIGINS=http://localhost:5173
# Production (your Netlify URL):
# CORS_ORIGINS=https://your-app.netlify.app

# Save debug images during piece detection (default: false)
# DEBUG_DETECTION=false
